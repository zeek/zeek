##! Events generated by the DHCPv6 analyzer.

  @if ( have_spicy_analyzers() )

  module DHCPv6;

  ## Generated for each parsed DHCPv6 message.
  ##
  ## c: The connection.
  ##
  ## is_orig: Whether the message came from the originator.
  ##
  ## msg: Flat summary of the parsed message (see :zeek:type:`DHCPv6::MessageInfo`).
  global DHCPv6::dhcpv6_message: event(c: connection, is_orig: bool, msg: MessageInfo);

  @endif