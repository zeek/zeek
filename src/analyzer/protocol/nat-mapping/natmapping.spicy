module NATMapping;

import spicy;
import natpmp;
import pcp;

public type Packet = unit {
    %port = 5351/udp;

    version: uint8;
    switch (self.version) {
        0 -> natpmp: NATPMP::Record();
        2 -> pcp: PCP::Record();
    };
};
