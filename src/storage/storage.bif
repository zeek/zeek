	}

	if ( expire_time > 0.0 )
		expire_time += zeek::run_state::network_time;

	auto cb = new zeek::storage::OperationResultCallback();
	auto key_v = zeek::IntrusivePtr<Val>{NewRef{}, key};
	auto val_v = zeek::IntrusivePtr<Val>{NewRef{}, value};
	auto put_res = b->backend->Put(key_v, val_v, overwrite, expire_time, cb);

	// If the backend only supports async, block until it's ready and then pull the result out of
	// the callback.
	if ( ! b->backend->SupportsSync() ) {
		b->backend->Poll();
		put_res = cb->Result();
	}

	delete cb;

	put_res.FillRecordVal(op_result);
	return op_result;
	%}

